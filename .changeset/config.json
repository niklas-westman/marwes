{
  "$schema": "https://unpkg.com/@changesets/config@3.0.3/schema.json",
  "changelog": [
    "@changesets/changelog-github",
    {
      "repo": "niklas-westman/marwes"
    }
  ],
  "commit": false,
  "fixed": [
    [
      "@marwes-ui/core",
      "@marwes-ui/react",
      "@marwes-ui/presets",
      "@marwes-ui/vue",
      "@marwes-ui/svelte"
    ]
  ],
  "linked": [["@marwes-ui/cli", "create-marwes"]],
  "access": "public",
  "baseBranch": "main",
  "updateInternalDependencies": "patch",
  "ignore": [
    "dashboard-teaser",
    "playground-react",
    "playground-svelte",
    "storybook-react",
    "storybook-svelte",
    "storybook-vue"
  ]
}
