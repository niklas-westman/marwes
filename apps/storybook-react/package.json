{
  "name": "storybook-react",
  "private": true,
  "version": "0.0.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:a11y:smoke": "vitest run --config vite.config.ts --project storybook",
    "build": "tsc -b --noEmit && storybook build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@marwes-ui/core": "workspace:*",
    "@marwes-ui/react": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.0.0",
    "@eslint/js": "9.39.2",
    "@storybook/addon-a11y": "10.2.6",
    "@storybook/addon-docs": "10.2.6",
    "@storybook/addon-themes": "10.2.8",
    "@storybook/addon-vitest": "10.2.6",
    "@storybook/addons": "7.6.17",
    "@storybook/components": "8.6.14",
    "@storybook/core-events": "8.6.14",
    "@storybook/manager-api": "8.6.14",
    "@storybook/react": "10.2.6",
    "@storybook/react-vite": "10.2.6",
    "@storybook/types": "8.6.14",
    "@types/node": "24.10.10",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.3",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "eslint-plugin-storybook": "10.2.6",
    "globals": "16.5.0",
    "playwright": "1.58.1",
    "storybook": "10.2.10",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vite": "7.3.2",
    "vitest": "4.0.18"
  }
}
