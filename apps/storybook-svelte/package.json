{
  "name": "storybook-svelte",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "typecheck": "svelte-check --tsconfig ./tsconfig.check.json",
    "test": "vitest run",
    "test:a11y:smoke": "vitest run --config vite.config.ts --project storybook",
    "build": "storybook build",
    "storybook": "storybook dev -p 6008",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@marwes-ui/core": "workspace:*",
    "@marwes-ui/svelte": "workspace:*"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.0.0",
    "@storybook/addon-a11y": "10.3.6",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-themes": "10.3.6",
    "@storybook/addon-vitest": "10.2.6",
    "@storybook/svelte": "10.3.6",
    "@storybook/svelte-vite": "10.3.6",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@types/node": "24.10.10",
    "@vitest/browser-playwright": "4.0.18",
    "playwright": "1.58.1",
    "storybook": "10.3.6",
    "svelte": "^5.20.0",
    "svelte-check": "^4.0.0",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "4.0.18"
  }
}
