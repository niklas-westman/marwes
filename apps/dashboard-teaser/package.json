{
  "name": "dashboard-teaser",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b --noEmit",
    "check:button-variants": "node ../../scripts/check-dashboard-button-variants.mjs",
    "test:seo": "vitest run --config vitest.config.ts",
    "test": "pnpm check:button-variants && pnpm test:seo",
    "build": "pnpm check:button-variants && tsc -b --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@marwes-ui/react": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "styled-components": "6.3.11"
  },
  "devDependencies": {
    "@types/node": "24.10.10",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "@types/styled-components": "5.1.36",
    "@vitejs/plugin-react": "5.1.3",
    "typescript": "5.9.3",
    "vite": "7.3.6"
  }
}
