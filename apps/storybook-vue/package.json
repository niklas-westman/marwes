{
  "name": "storybook-vue",
  "private": true,
  "version": "0.0.5",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:a11y:smoke": "vitest run --config vite.config.ts --project storybook src/stories/button/button.stories.ts src/stories/checkbox/checkbox-field.stories.ts src/stories/radio/radio-group-field.stories.ts src/stories/toast/toast.stories.ts src/stories/spinner/spinner.stories.ts src/stories/skeleton/skeleton.stories.ts src/stories/stat-tile/stat-tile.stories.ts",
    "build": "tsc -b --noEmit && storybook build",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@marwes-ui/core": "workspace:*",
    "@marwes-ui/vue": "workspace:*",
    "vue": "3.5.28"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.0.0",
    "@storybook/addon-a11y": "10.2.6",
    "@storybook/addon-docs": "10.2.6",
    "@storybook/addon-themes": "10.2.8",
    "@storybook/addon-vitest": "10.2.6",
    "@storybook/manager-api": "8.6.14",
    "@storybook/vue3": "10.2.10",
    "@storybook/vue3-vite": "10.2.10",
    "@types/node": "24.10.10",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-vue": "6.0.4",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "playwright": "1.58.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "storybook": "10.2.10",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "4.0.18"
  }
}
