  "storybook": {
    "_note": "Map these Storybook theme keys to Marwes semantic tokens — do not hardcode hex values",
    "textMuted": "text.secondary",
    "textSubtle": "text.disabled",
    "danger": "status.error.icon — fill/icon use only, not text",
    "success": "status.success.icon — fill/icon use only, not text",
    "warning": "status.warning.icon — fill/icon use only, not text"
  }
