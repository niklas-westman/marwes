  "_meta": {
    "description": "Marwes design system — color tokens export",
    "date": "2026-05-06",
    "version": "2",
    "changelog": [
      "New primitives: Neutral/25 (#F8F8F8), Neutral/50 (#FAFAFA), Neutral/150 (#D8D8D8)",
      "surface/primary light: #FFFFFF (was #F9FAFB)",
      "surface/secondary light: #F8F8F8 (was #FFFFFF)",
      "surface/sunken light: #F5F5F5 (was #F3F4F6)",
      "surface/primary dark: #0F0F0F (was #141414)",
      "surface/secondary dark: #1A1A1A (was #2E2E2E)",
      "surface/raised dark: #2B2B2B (was #474747)",
      "surface/sunken dark: #050505 (was #000000)",
      "surface/disabled: added explicit neutral disabled surface token",
      "border/default light: #D8D8D8 (was #E5E7EB)",
      "action/ghost/hover light: #F5F5F5 (was #F3F4F6)",
      "action/ghost/active light: #E8E8E8 (was #E5E7EB)",
      "Storybook: textMuted → text.secondary, textSubtle → text.disabled"
    ]
  },

