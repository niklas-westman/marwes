{
  "name": "@marwes-ui/presets",
  "version": "1.0.4",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "private": false,
  "type": "module",
  "sideEffects": ["*.css", "**/*.css"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./firstEdition": {
      "types": "./dist/firstEdition/index.d.ts",
      "default": "./dist/firstEdition/index.js"
    },
    "./firstEdition/styles.css": "./src/firstEdition/styles.css"
  },
  "files": ["dist", "src/firstEdition"],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@fontsource/instrument-sans": "5.2.8",
    "@marwes-ui/core": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "6.1.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
