{
  "name": "@marwes-ui/react",
  "version": "1.0.4",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "private": false,
  "type": "module",
  "sideEffects": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@marwes-ui/core": "workspace:*",
    "@marwes-ui/presets": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rimraf": "6.1.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
