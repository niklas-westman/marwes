{
  "name": "@marwes-ui/cli",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "marwes": "dist/cli.js",
    "marwes-ui": "dist/cli.js"
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "NODE_ENV=test vitest run --config vitest.config.ts",
    "clean": "rimraf dist",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@types/node": "24.10.10",
    "rimraf": "6.1.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
